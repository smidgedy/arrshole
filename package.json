{
  "name": "arrshole",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "test:coverage": "c8 --include 'src/**/*.ts' --exclude 'src/**/*.test.ts' node --import tsx --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
