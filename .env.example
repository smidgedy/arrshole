# qBittorrent (required)
QBIT_URL=http://localhost:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=

# Sonarr (optional — at least one *arr must be configured)
SONARR_URL=http://localhost:8989
SONARR_API_KEY=

# Radarr (optional)
RADARR_URL=http://localhost:7878
RADARR_API_KEY=

# Lidarr (optional)
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=

# Category mapping (optional — defaults to exact name match: "sonarr", "radarr", "lidarr")
# Format: comma-separated category:app pairs for custom category names
# CATEGORY_MAP=tv-sonarr:sonarr,movies:radarr,music:lidarr

# Behavior
POLL_INTERVAL_SECONDS=60
METADATA_STUCK_MINUTES=10
# Stalled thresholds: maxPercent:hours pairs. Torrents at or below maxPercent% progress
# will be cleared after the specified hours stalled. Last entry must cover 100%.
# Default "100:24" = flat 24h for all. Example tiered: "10:1,90:12,100:24"
STALLED_THRESHOLDS=100:24
MAX_ACTIONS_PER_CYCLE=5
DRY_RUN=true
LOG_LEVEL=info
# STATE_FILE=./arrshole-state.json
